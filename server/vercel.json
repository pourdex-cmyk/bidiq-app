{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "env": {
    "SUPABASE_URL": "@bidiq-supabase-url",
    "SUPABASE_SERVICE_ROLE_KEY": "@bidiq-supabase-service-role-key",
    "ALLOWED_ORIGINS": "@bidiq-allowed-origins"
  }
}
